<path d="M 260 180 C 188 180, 152 180, 80 180" fill="none" stroke="var(--text-muted)" stroke-width="2" class="canvas-edge" data-edge-id="92c941a9475ec26a"  marker-end="url(#arrow-vartextmuted)" />
