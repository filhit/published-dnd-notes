---
{"dg-publish":true,"dg-content-classes":"canvas-page","permalink":"/test-canvas.canvas/","contentClasses":"canvas-page","dgPassFrontmatter":true}
---

<div id="test_canvascanvas" class="canvas-wrapper hide">
	<svg class="canvas-background">
		<defs>
			<pattern id="canvas-grid-test_canvascanvas" width="25" height="25" patternUnits="userSpaceOnUse">
				<circle r="1.5" cx="12.5" cy="12.5"></circle>
			</pattern>
		</defs>
		<rect width="100%" height="100%" fill="url(#canvas-grid-test_canvascanvas)"></rect>
	</svg>
	<div class="canvas">
		<svg class="canvas-edges-container" style="position:absolute;width:1px;height:1px;overflow:visible;">
			<defs><marker id="arrow-vartextmuted" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto" markerUnits="strokeWidth">
			<path d="M0,0.5 L5,3 L0,5.5" fill="none" stroke="var(--text-muted)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
		</marker>
		<marker id="arrow-vartextmuted-start" markerWidth="6" markerHeight="6" refX="1" refY="3" orient="auto-start-reverse" markerUnits="strokeWidth">
			<path d="M6,0.5 L1,3 L6,5.5" fill="none" stroke="var(--text-muted)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
		</marker><filter x="-0.1" y="-0.1" width="1.2" height="1.3" id="edge-label-bg">
			<feFlood flood-color="var(--background-primary)" flood-opacity="1" result="bg"/>
			<feMerge>
				<feMergeNode in="bg"/>
				<feMergeNode in="SourceGraphic"/>
			</feMerge>
		</filter></defs><path d="M 0 -96 C 0 -258.07504434674695, 31 -337.92495565325305, 31 -500" fill="none" stroke="var(--text-muted)" stroke-width="2" class="canvas-edge" data-edge-id="20343e709c57f725"  marker-end="url(#arrow-vartextmuted)" />
		</svg>
		<div class="canvas-node canvas-node-text " data-node-id="9c68e640b362efd5" style="transform: translate(-125px, -96px); width: 250px; height: 60px; ">
	<div class="canvas-node-container">
		<div class="canvas-node-content markdown-rendered">
			<div class="canvas-node-text-content" data-markdown="0LrQsNGA0YLQvtGH0LrQsCBbW9CY0L7Qs9Cw0L3QvSDQkdGA0LDRg9C9XHzQmNC+0LPQsNC90L1dXQ=="></div>
		</div>
	</div>
</div>
<div class="canvas-node canvas-node-file has-color" data-node-id="daeaf73b3ca3faf8" data-file-path="Иоганн Браун.md" style="transform: translate(-169px, -762px); width: 400px; height: 262px; --canvas-color: #fb464c;">
	<div class="canvas-node-label">Иоганн Браун</div>
	<div class="canvas-node-container">
		<div class="canvas-node-content markdown-embed">
			<iframe src="/iogann-braun//" class="canvas-file-iframe" loading="lazy"></iframe>
		</div>
	</div>
</div>
	</div>
</div>
